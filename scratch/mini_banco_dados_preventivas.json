      "padronizacao_status_mensal": "O campo 'status' na coleção 'distribuicao_mensal' deve ser tratado como um tipo ENUM restrito exclusivamente a ['PENDENTE', 'REALIZADA', 'EM ATENDIMENTO']."
    }
